{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source.schema.json",
  "type": "object",
  "required": [
    "title",
    "url"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "page": {
      "type": [
        "integer",
        "null"
      ]
    },
    "url": {
      "type": "string",
      "format": "uri"
    }
  },
  "additionalProperties": false
}
