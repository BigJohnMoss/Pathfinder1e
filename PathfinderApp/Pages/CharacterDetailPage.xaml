<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PathfinderApp.Pages.CharacterDetailPage"
    Title="Character">

    <ScrollView>
        <VerticalStackLayout Padding="10" Spacing="8">
            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="Large" />
            <Entry Text="{Binding Name, Mode=TwoWay}" />
            <Entry Text="{Binding Level, Mode=TwoWay}" />
            <Editor Text="{Binding Summary, Mode=TwoWay}" HeightRequest="120" />

            <HorizontalStackLayout Spacing="12">
                <Button Text="Save" Clicked="OnSaveClicked" />
                <Button Text="Delete" Clicked="OnDeleteClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
