<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PathfinderApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PathfinderApp"
    xmlns:pages="clr-namespace:PathfinderApp.Pages"
    Title="PathfinderApp">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <FlyoutItem Title="Characters" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent Title="Characters" ContentTemplate="{DataTemplate pages:CharactersPage}" Route="CharactersPage" />
    </FlyoutItem>

</Shell>
